<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="m0609">
    <!--
        Doosan m0609 URDF for Isaac Sim + MoveIt2.
        ros2_control_hardware_type:
          - "isaac"           : TopicBasedSystem (default, for Isaac Sim)
          - "mock_components" : GenericSystem (standalone testing without simulator)
    -->
    <xacro:arg name="ros2_control_hardware_type" default="isaac" />

    <!-- Doosan m0609 robot description -->
    <xacro:include filename="$(find dsr_description2)/urdf/m0609.urdf" />

    <!-- Isaac-compatible ros2_control hardware interface (shared by all Doosan 6-DOF models) -->
    <xacro:include filename="$(find isaac_moveit)/config/dsr_isaac.ros2_control.xacro" />

    <xacro:dsr_isaac_ros2_control
        name="DSRIsaacSystem"
        ros2_control_hardware_type="$(arg ros2_control_hardware_type)" />
</robot>
