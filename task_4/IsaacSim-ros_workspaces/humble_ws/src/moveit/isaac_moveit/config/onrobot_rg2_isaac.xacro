<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <!--
        OnRobot RG2 그리퍼 macro — Isaac Sim + MoveIt2 전용.

        onrobot_rg2 패키지가 ROS2 ament index에 등록되어 있지 않으므로
        mesh 경로를 절대경로로 직접 지정합니다.

        파라미터:
          prefix  : 링크/조인트 이름 앞에 붙을 접두사 (예: "rg2_")
          parent  : 그리퍼를 붙일 부모 링크 (예: "link_6")
          *origin : 부착 조인트의 <origin xyz="..." rpy="..."/> 블록
    -->
    <!-- RViz2 는 절대 경로에 file:// prefix 가 필요합니다 -->
    <xacro:property name="rg2_mesh"
        value="file:///home/ssu/dev_ws/issac_sim/src/onrobot_rg2/meshes"/>

    <xacro:macro name="onrobot_rg2" params="prefix parent *origin">

        <!-- ── Links ─────────────────────────────────────────────────── -->
        <link name="${prefix}quick_changer">
            <inertial>
                <origin xyz="0.001467 -0.000740 0.003911" rpy="0 0 0"/>
                <mass value="0.058020"/>
                <inertia ixx="2.0e-05" iyy="2.7e-05" izz="4.5e-05"
                         ixy="-0.0" iyz="0.0" ixz="-0.0"/>
            </inertial>
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="${rg2_mesh}/visual/quick_changer.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
                <material name="rg2_blue">
                    <color rgba="0.216 0.592 0.812 1.0"/>
                </material>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="${rg2_mesh}/collision/quick_changer.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
            </collision>
        </link>

        <link name="${prefix}angle_bracket">
            <inertial>
                <origin xyz="-0.000236 0.000641 0.019939" rpy="0 0 0"/>
                <mass value="0.197570"/>
                <inertia ixx="9.8e-05" iyy="1.45e-04" izz="1.55e-04"
                         ixy="-0.0" iyz="2.0e-06" ixz="-1.0e-06"/>
            </inertial>
            <visual>
                <origin xyz="0.0 0.0 -0.00255" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="${rg2_mesh}/visual/angle_bracket.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
                <material name="rg2_silver">
                    <color rgba="0.7 0.7 0.7 1.0"/>
                </material>
            </visual>
            <collision>
                <origin xyz="0.0 0.0 -0.00255" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="${rg2_mesh}/collision/angle_bracket.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
            </collision>
        </link>

        <link name="${prefix}gripper_body">
            <inertial>
                <origin xyz="0.027297 -0.002438 0.035298" rpy="0 0 0"/>
                <mass value="0.570779"/>
                <inertia ixx="6.22e-04" iyy="6.62e-04" izz="2.26e-04"
                         ixy="3.0e-06" iyz="1.8e-05" ixz="0.0"/>
            </inertial>
            <visual>
                <origin xyz="0.02705 0.0 -0.047" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="${rg2_mesh}/visual/gripper_body.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
                <material name="rg2_silver"/>
            </visual>
            <collision>
                <origin xyz="0.02705 0.0 -0.047" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="${rg2_mesh}/collision/gripper_body.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
            </collision>
        </link>

        <link name="${prefix}right_outer_knuckle">
            <inertial>
                <origin xyz="-0.012312 0.010370 0.010204" rpy="0 0 0"/>
                <mass value="0.041584"/>
                <inertia ixx="1.0e-05" iyy="1.6e-05" izz="1.0e-05"
                         ixy="0.0" iyz="-0.0" ixz="7.0e-06"/>
            </inertial>
            <visual>
                <origin xyz="0.017 0.009534 -0.122898" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="${rg2_mesh}/visual/right_outer_knuckle.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
                <material name="rg2_silver"/>
            </visual>
            <collision>
                <origin xyz="0.017 0.009534 -0.122898" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="${rg2_mesh}/collision/right_outer_knuckle.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
            </collision>
        </link>

        <link name="${prefix}left_outer_knuckle">
            <inertial>
                <origin xyz="0.012312 0.010370 0.010204" rpy="0 0 0"/>
                <mass value="0.041584"/>
                <inertia ixx="1.0e-05" iyy="1.6e-05" izz="1.0e-05"
                         ixy="-0.0" iyz="-0.0" ixz="-7.0e-06"/>
            </inertial>
            <visual>
                <origin xyz="-0.017 0.009534 -0.122898" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="${rg2_mesh}/visual/left_outer_knuckle.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
                <material name="rg2_silver"/>
            </visual>
            <collision>
                <origin xyz="-0.017 0.009534 -0.122898" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="${rg2_mesh}/collision/left_outer_knuckle.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
            </collision>
        </link>

        <link name="${prefix}left_inner_knuckle">
            <inertial>
                <origin xyz="0.017629 0.010472 0.017068" rpy="0 0 0"/>
                <mass value="0.024338"/>
                <inertia ixx="5.0e-06" iyy="7.0e-06" izz="5.0e-06"
                         ixy="-0.0" iyz="-0.0" ixz="-3.0e-06"/>
            </inertial>
            <visual>
                <origin xyz="-0.0075 0.009367 -0.139397" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="${rg2_mesh}/visual/left_inner_knuckle.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
                <material name="rg2_silver"/>
            </visual>
            <collision>
                <origin xyz="-0.0075 0.009367 -0.139397" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="${rg2_mesh}/collision/left_inner_knuckle.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
            </collision>
        </link>

        <link name="${prefix}right_inner_knuckle">
            <inertial>
                <origin xyz="-0.017629 0.010472 0.017068" rpy="0 0 0"/>
                <mass value="0.024338"/>
                <inertia ixx="5.0e-06" iyy="7.0e-06" izz="5.0e-06"
                         ixy="0.0" iyz="-0.0" ixz="3.0e-06"/>
            </inertial>
            <visual>
                <origin xyz="0.0075 0.009367 -0.139397" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="${rg2_mesh}/visual/right_inner_knuckle.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
                <material name="rg2_silver"/>
            </visual>
            <collision>
                <origin xyz="0.0075 0.009367 -0.139397" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="${rg2_mesh}/collision/right_inner_knuckle.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
            </collision>
        </link>

        <link name="${prefix}left_inner_finger">
            <inertial>
                <origin xyz="-0.009341 0.006109 0.031337" rpy="0 0 0"/>
                <mass value="0.032039"/>
                <inertia ixx="9.0e-06" iyy="9.0e-06" izz="2.0e-06"
                         ixy="0.0" iyz="-0.0" ixz="2.0e-06"/>
            </inertial>
            <visual>
                <origin xyz="-0.056748 0.00475 -0.160866" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="${rg2_mesh}/visual/left_inner_finger.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
                <material name="rg2_silver"/>
            </visual>
            <collision>
                <origin xyz="-0.056748 0.00475 -0.160866" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="${rg2_mesh}/collision/left_inner_finger.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
            </collision>
        </link>

        <link name="${prefix}right_inner_finger">
            <inertial>
                <origin xyz="0.009341 0.006109 0.031337" rpy="0 0 0"/>
                <mass value="0.032039"/>
                <inertia ixx="9.0e-06" iyy="9.0e-06" izz="2.0e-06"
                         ixy="-0.0" iyz="-0.0" ixz="-2.0e-06"/>
            </inertial>
            <visual>
                <origin xyz="0.056748 0.00475 -0.160866" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="${rg2_mesh}/visual/right_inner_finger.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
                <material name="rg2_silver"/>
            </visual>
            <collision>
                <origin xyz="0.056748 0.00475 -0.160866" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="${rg2_mesh}/collision/right_inner_finger.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
            </collision>
        </link>

        <!-- ── Joints ────────────────────────────────────────────────── -->

        <!-- link_6 → quick_changer : 사용자 지정 origin -->
        <joint name="${prefix}quick_changer_joint" type="fixed">
            <parent link="${parent}"/>
            <child  link="${prefix}quick_changer"/>
            <xacro:insert_block name="origin"/>
        </joint>

        <joint name="${prefix}angle_bracket_joint" type="fixed">
            <origin xyz="0.0 0.0 0.00255" rpy="0 0 0"/>
            <parent link="${prefix}quick_changer"/>
            <child  link="${prefix}angle_bracket"/>
        </joint>

        <joint name="${prefix}gripper_body_joint" type="fixed">
            <origin xyz="-0.02705 0.0 0.04445" rpy="0.010123 0 0"/>
            <parent link="${prefix}angle_bracket"/>
            <child  link="${prefix}gripper_body"/>
        </joint>

        <!-- 메인 구동 조인트 (ros2_control 에서 제어) -->
        <joint name="${prefix}finger_joint" type="revolute">
            <origin xyz="0.01005 -0.009534 0.075898" rpy="0 -0.415388 0"/>
            <parent link="${prefix}gripper_body"/>
            <child  link="${prefix}right_outer_knuckle"/>
            <axis xyz="0.0 0.999949 -0.010122"/>
            <limit lower="0.0" upper="1.18" effort="50.0" velocity="2.0"/>
        </joint>

        <!-- 미믹 조인트 (finger_joint 를 따라 움직이는 수동 조인트) -->
        <joint name="${prefix}left_outer_knuckle_joint" type="revolute">
            <origin xyz="0.04405 -0.009534 0.075898" rpy="0 0.415388 0"/>
            <parent link="${prefix}gripper_body"/>
            <child  link="${prefix}left_outer_knuckle"/>
            <axis xyz="0.0 0.999949 -0.010122"/>
            <limit lower="-1.19" upper="0.01" effort="50.0" velocity="2.0"/>
            <mimic joint="${prefix}finger_joint" multiplier="-1" offset="0"/>
        </joint>

        <joint name="${prefix}left_inner_knuckle_joint" type="revolute">
            <origin xyz="0.03455 -0.009367 0.092397" rpy="0 0.415388 0"/>
            <parent link="${prefix}gripper_body"/>
            <child  link="${prefix}left_inner_knuckle"/>
            <axis xyz="0.0 0.999949 -0.010122"/>
            <limit lower="-1.19" upper="0.01" effort="50.0" velocity="2.0"/>
            <mimic joint="${prefix}finger_joint" multiplier="-1" offset="0"/>
        </joint>

        <joint name="${prefix}left_inner_finger_joint" type="revolute">
            <origin xyz="0.039748 0.004784 0.037968" rpy="0 -0.415388 0"/>
            <parent link="${prefix}left_outer_knuckle"/>
            <child  link="${prefix}left_inner_finger"/>
            <axis xyz="0.0 -0.999949 0.010122"/>
            <limit lower="-1.19" upper="0.01" effort="50.0" velocity="2.0"/>
            <mimic joint="${prefix}finger_joint" multiplier="-1" offset="0"/>
        </joint>

        <joint name="${prefix}right_inner_finger_joint" type="revolute">
            <origin xyz="-0.039748 0.004784 0.037968" rpy="0 0.415388 0"/>
            <parent link="${prefix}right_outer_knuckle"/>
            <child  link="${prefix}right_inner_finger"/>
            <axis xyz="0.0 0.999949 -0.010122"/>
            <limit lower="-1.19" upper="0.01" effort="50.0" velocity="2.0"/>
            <mimic joint="${prefix}finger_joint" multiplier="-1" offset="0"/>
        </joint>

        <joint name="${prefix}right_inner_knuckle_joint" type="revolute">
            <origin xyz="0.01955 -0.009367 0.092397" rpy="0 -0.415388 0"/>
            <parent link="${prefix}gripper_body"/>
            <child  link="${prefix}right_inner_knuckle"/>
            <axis xyz="0.0 0.999949 -0.010122"/>
            <limit lower="-0.01" upper="1.19" effort="50.0" velocity="2.0"/>
            <mimic joint="${prefix}finger_joint" multiplier="1" offset="0"/>
        </joint>

    </xacro:macro>
</robot>
